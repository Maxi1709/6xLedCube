INCLUDES
*/
#include "config/config.ino"
#include "utility/pinSet.ino"
/*################################################################################################*/

/*
####################################################################################################
FUNCTION NAME
setup()
----------------------------------------------------------------------------------------------------
DESCRIPTION
This function is run once at startup.
 Tasks:
    > Set all IO-pins configured in pins[] as output.
      Initialize all these pins with LOW value.
----------------------------------------------------------------------------------------------------
PARAMETERS
none
----------------------------------------------------------------------------------------------------
RETURN
void
####################################################################################################
*/
void setup()
{
  for(int i : pins)
  {
    pinMode(i, OUTPUT);
    digitalWrite(i, LOW);
  }
}